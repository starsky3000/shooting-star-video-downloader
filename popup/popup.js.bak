// StarDownload Popup Script

let currentVideoInfo = null;
let downloadComplete = false;
let currentVideoId = null; // Track current video to persist state

// DOM Elements
const thumbnail = document.getElementById('thumbnail');
const videoTitle = document.getElementById('videoTitle');
const qualitySelect = document.getElementById('qualitySelect');
const downloadBtn = document.getElementById('downloadBtn');
const btnText = document.getElementById('btnText');
const progressSection = document.getElementById('progressSection');
const progressBar = document.getElementById('progressBar');
const statusText = document.getElementById('statusText');
const completionSection = document.getElementById('completionSection');
const successText = document.getElementById('successText');
const filePath = document.getElementById('filePath');
const playBtn = document.getElementById('playBtn');
const openFolderBtn = document.getElementById('openFolderBtn');
const errorSection = document.getElementById('errorSection');
const errorMessage = document.getElementById('errorMessage');
const retryBtn = document.getElementById('retryBtn');

// Initialize popup
document.addEventListener('DOMContentLoaded', async () => {
  // Check if on YouTube video page
  const [tab] = await chrome.tabs.query({ active: true, currentWindow: true });

  if (!tab.url || !tab.url.includes('youtube.com/watch')) {
    showError('请在 YouTube 视频页面使用此扩展');
    return;
  }

  // Check yt-dlp version first
  setCheckingVersionState();

  try {
    const versionInfo = await chrome.runtime.sendMessage({ type: 'checkVersion' });
    if (!versionInfo.isLatest) {
      // Show updating state
      setUpdatingState(versionInfo.requiredVersion, versionInfo.currentVersion);

      // Trigger update
      try {
        const port = chrome.runtime.connectNative('com.stardownload.host');
        port.onMessage.addListener((response) => {
          if (response.type === 'updateComplete') {
            port.disconnect();
            if (response.success) {
              // Update successful, reload page to continue
              setDownloadReadyState();
            } else {
              showError('yt-dlp 更新失败，请手动更新: pipx install yt-dlp');
            }
          }
        });
        port.postMessage({ action: 'updateYtDlp' });
      } catch (err) {
        showError('无法启动 yt-dlp 更新');
      }
    } else {
      // Version is latest, proceed normal
      setDownloadReadyState();
    }
  } catch (err) {
    // Version check failed, assume old
    setUpdatingState('2026.03.17', null);
  }

  // Get video info from content script
  try {
    const response = await chrome.tabs.sendMessage(tab.id, { action: 'getVideoInfo' });
    if (response && response.success) {
      currentVideoInfo = response.data;

      // Extract video ID to check if it's the same video
      const urlParams = new URLSearchParams(new URL(currentVideoInfo.url).search);
      const videoId = urlParams.get('v');

      // If same video, restore previous state instead of resetting
      if (videoId === currentVideoId && currentVideoId !== null) {
        restoreState();
      } else {
        // Different video - reset state
        currentVideoId = videoId;
        displayVideoInfo(currentVideoInfo);
        // Don't reset state if we're still in updating mode
      }
    } else {
      showError('无法获取视频信息');
    }
  } catch (err) {
    showError('无法连接到 YouTube 页面，请刷新后重试');
  }

  // Set up event listeners
  downloadBtn.addEventListener('click', startDownload);
  playBtn.addEventListener('click', playVideo);
  openFolderBtn.addEventListener('click', openFolder);
  retryBtn.addEventListener('click', resetState);
});

// Set checking version state
function setCheckingVersionState() {
  downloadBtn.disabled = true;
  btnText.textContent = '检查更新...';
  progressSection.style.display = 'block';
  progressBar.style.width = '0%';
  statusText.textContent = '正在检查 yt-dlp 版本...';
  completionSection.style.display = 'none';
  errorSection.style.display = 'none';
}

// Set updating state
function setUpdatingState(required, current) {
  downloadBtn.disabled = true;
  btnText.textContent = '更新中...';
  progressSection.style.display = 'block';
  progressBar.style.width = '50%';
  statusText.textContent = `正在更新 yt-dlp (${current || '未知版本'} → ${required})`;
  completionSection.style.display = 'none';
  errorSection.style.display = 'none';
}

// Set download ready state
function setDownloadReadyState() {
  downloadBtn.disabled = false;
  btnText.textContent = '下载';
  progressSection.style.display = 'block';
  progressBar.style.width = '0%';
  statusText.textContent = '准备就绪';
}

// Restore previous state for same video
async function restoreState() {
  try {
    const response = await chrome.runtime.sendMessage({ type: 'getDownloadState' });
    if (response && response.status === 'downloading') {
      // Show downloading state
      setDownloadingState();
      progressBar.style.width = `${response.progress}%`;
      statusText.textContent = response.statusText || `下载中... ${response.progress.toFixed(1)}%`;
    } else if (response && response.status === 'complete') {
      showCompletion(response.filePath);
    } else if (response && response.status === 'error') {
      showError(response.errorMessage || '下载失败');
    } else {
      displayVideoInfo(currentVideoInfo);
    }
  } catch (err) {
    displayVideoInfo(currentVideoInfo);
  }
}

// Display video information
function displayVideoInfo(info) {
  thumbnail.src = info.thumbnail;
  videoTitle.textContent = info.title;
}

// Start download process
async function startDownload() {
  if (!currentVideoInfo) {
    showError('视频信息无效');
    return;
  }

  setDownloadingState();

  const quality = qualitySelect.value;
  const downloadRequest = {
    action: 'download',
    url: currentVideoInfo.url,
    title: currentVideoInfo.title,
    quality: quality
  };

  try {
    // Set up port for native messaging
    const port = chrome.runtime.connectNative('com.stardownload.host');

    port.onMessage.addListener((response) => {
      handleNativeMessage(response);
    });

    port.onDisconnect.addListener(() => {
      if (!downloadComplete) {
        showError('连接中断，请重试');
      }
    });

    // Send download request
    port.postMessage(downloadRequest);

  } catch (err) {
    showError('无法启动下载：' + err.message);
  }
}

// Handle messages from native host
function handleNativeMessage(message) {
  switch (message.type) {
    case 'progress':
      updateProgress(message.percent, message.status);
      // Send progress to background to persist
      chrome.runtime.sendMessage({
        type: 'downloadProgress',
        percent: message.percent,
        status: message.status
      }).catch(() => {});
      break;
    case 'complete':
      downloadComplete = true;
      showCompletion(message.filePath);
      chrome.runtime.sendMessage({
        type: 'downloadComplete',
        filePath: message.filePath
      }).catch(() => {});
      break;
    case 'error':
      downloadComplete = true;
      showError(message.message);
      chrome.runtime.sendMessage({
        type: 'downloadError',
        message: message.message
      }).catch(() => {});
      break;
  }
}

// Update progress display
function updateProgress(percent, status) {
  progressBar.style.width = `${percent}%`;
  statusText.textContent = status || `下载中... ${percent.toFixed(1)}%`;
}

// Show completion state
function showCompletion(path) {
  progressSection.style.display = 'none';
  errorSection.style.display = 'none';
  completionSection.style.display = 'block';
  filePath.textContent = path;
  downloadComplete = true;
}

// Show error state
function showError(message) {
  progressSection.style.display = 'none';
  completionSection.style.display = 'none';
  errorSection.style.display = 'block';
  errorMessage.textContent = message;
  downloadBtn.disabled = false;
  btnText.textContent = '下载';
}

// Set downloading state
function setDownloadingState() {
  downloadBtn.disabled = true;
  btnText.textContent = '正在准备下载...';
  progressSection.style.display = 'block';
  progressBar.style.width = '0%';
  statusText.textContent = '正在解析视频信息...';
  completionSection.style.display = 'none';
  errorSection.style.display = 'none';
}

// Reset to initial state
function resetState() {
  downloadBtn.disabled = false;
  btnText.textContent = '下载';
  progressSection.style.display = 'block';
  progressBar.style.width = '0%';
  statusText.textContent = '准备就绪';
  errorSection.style.display = 'none';
  downloadComplete = false;
}

// Play video (via native host)
async function playVideo() {
  try {
    const port = chrome.runtime.connectNative('com.stardownload.host');
    port.postMessage({
      action: 'openFile',
      filePath: filePath.textContent
    });
    port.disconnect();
  } catch (err) {
    showError('无法打开视频：' + err.message);
  }
}

// Open folder (via native host)
async function openFolder() {
  try {
    const port = chrome.runtime.connectNative('com.stardownload.host');
    port.postMessage({
      action: 'openFolder',
      filePath: filePath.textContent
    });
    port.disconnect();
  } catch (err) {
    showError('无法打开文件夹：' + err.message);
  }
}